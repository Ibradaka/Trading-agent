# ============================================================
# Trading Agent — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# JAMAIS commiter .env dans git
# ============================================================

# --- Base de données ---
DATABASE_URL=postgresql+asyncpg://trading:password@postgres:5432/trading_agent
POSTGRES_PASSWORD=change_me_strong_password

# --- Redis ---
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=change_me_redis_password

# --- Sources de données ---
FRED_API_KEY=                    # Gratuit sur https://fred.stlouisfed.org/docs/api/api_key.html
ALPHA_VANTAGE_KEY=               # Gratuit sur https://www.alphavantage.co/support/#api-key (fallback uniquement)

# --- LLM ---
OPENAI_API_KEY=                  # https://platform.openai.com/api-keys
OPENAI_MODEL=gpt-4o-mini

# --- Telegram ---
TELEGRAM_BOT_TOKEN=              # @BotFather sur Telegram
TELEGRAM_CHAT_ID=                # Ton chat ID (envoyer /start à @userinfobot)

# --- Application ---
APP_ENV=development              # development | production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
DEFAULT_REFRESH_MINUTES=15       # Cadence de refresh par défaut
MARKET_OPEN_CET=09:00            # Heure ouverture marché (CET)
MARKET_CLOSE_CET=17:30           # Heure fermeture marché (CET)
MAX_ACTIVE_ASSETS=30             # Limite actifs actifs simultanés

# --- Frontend (exposées au navigateur) ---
NEXT_PUBLIC_API_URL=http://localhost:8899
API_PUBLIC_URL=https://ton-domaine.com  # En prod uniquement
